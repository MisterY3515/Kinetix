// test_for_loop.kix - compile_for regression coverage (Build 38 Phase A):
// bounds-check loop termination (not element truthiness), range loops, and
// the register-aliasing bug fixed alongside it.

mut sum = 0
for x in [1, 2, 3, 4, 5] {
    sum = sum + x
}
assert(sum == 15)

// Regression: previously the loop terminated as soon as it fetched a falsy
// element (0) instead of checking the array length, silently truncating
// the iteration.
mut count = 0
for x in [1, 0, 3, 2, 5] {
    count = count + 1
}
assert(count == 5)

// Range loops: 0..5 must materialize to [0,1,2,3,4] and iterate via GetIndex
// (Expression::Range previously fell through to a LoadNull stub and never
// reached the loop body at all).
mut total = 0
for i in 0..5 {
    total = total + i
}
assert(total == 10)

// Register-aliasing regression: the loop variable must not alias the
// iterable/index temp registers, so mutating other locals inside the body
// must not corrupt the loop variable or the iterable.
let arr = [100, 200, 300]
mut seen = [0, 0, 0]
mut i = 0
for v in arr {
    // The trailing `;` matters here: without it, the parser's Holy-Shell
    // implicit-call heuristic (crates/language/src/parser/mod.rs) can
    // misjudge a bare-identifier assignment RHS followed by another
    // statement on the next line as a call `v(i = i + 1)` -- a pre-existing
    // parser quirk unrelated to Build 38 Phase A, out of scope to fix here.
    seen[i] = v;
    i = i + 1
}
assert((seen[0] == 100) && (seen[1] == 200) && (seen[2] == 300))

println("test_for_loop: OK")
