// test_fail.kix - Combined intentional compiler error tests

// --- test_error_double_borrow.kix ---
// test_error_double_borrow.kix
// Verifies: Borrow Checker catches double mutable borrow
mut f = 5;
let ref1 = &mut f;
let ref2 = &mut f; // ERROR: Cannot borrow 'f' as mutable more than once at a time


// --- test_error_type_mismatch.kix ---
// test_error_type_mismatch.kix
// Verifies: Type Checker catches type mismatch errors
let err_a = 10;
let err_b = "string";
let err_c = err_a + err_b; // ERROR: Type mismatch int vs str


// --- test_error_use_after_move.kix ---
// test_error_use_after_move.kix
// Verifies: Borrow Checker catches use-after-move errors
let d = "hello resource";
let e = d; // 'd' is moved
println(d); // ERROR: Use of uninitialized or moved variable 'd'


// --- test_errors.kix ---
// test_errors.kix (Omnibus error test file)
// This file contains intentional errors for Kinetix error reporting.
// Note: Phases abort sequentially (Parser -> Symbol -> Typeck -> Borrowck).
// Errors from different phases won't be shown simultaneously.

// --- TYPE CHECKER ERRORS ---
let a = 10;
let b = "string";
let c = a + b; // ERROR 1: Type mismatch int vs str

let x: int = "hello"; // ERROR 2: Type mismatch str vs int

