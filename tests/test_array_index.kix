// test_array_index.kix - GetIndex/SetIndex regression coverage (Build 38 Phase A).
// Before this fix both opcodes were unimplemented in the VM and crashed at
// runtime on any array read/write.

let arr = [10, 20, 30]
assert(arr[0] == 10)
assert(arr[2] == 30)

mut m = [1, 2, 3]
m[1] = 99
assert(m[1] == 99)
assert(m[0] == 1)
assert(m[2] == 3)

println("test_array_index: OK")
