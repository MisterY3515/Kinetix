// Phase 4: system.defer RAII test — Build 26
// Verifies LIFO ordering of deferred closures

println("=== Kinetix Build 26: Defer RAII Test ===")

fn cleanup_c() {
    println("  [DEFER] Cleanup C executed (registered first, runs last)")
}

fn cleanup_b() {
    println("  [DEFER] Cleanup B executed (registered second)")
}

fn cleanup_a() {
    println("  [DEFER] Cleanup A executed (registered third, runs first)")
}

fn do_work() -> int {
    println("do_work: start")

    system.defer(cleanup_c)
    println("do_work: registered defer C")

    system.defer(cleanup_b)
    println("do_work: registered defer B")

    system.defer(cleanup_a)
    println("do_work: registered defer A")

    println("do_work: returning 42")
    return 42
}

let result = do_work()
print("Main got result: ")
println(result)

println("=== Defer test complete ===")
